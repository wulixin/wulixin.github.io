/**index.wxss**/
.container {
  padding: 40rpx 30rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.search-container {
  width: 100%;
  margin-bottom: 40rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.search-input {
  flex: 1;
  margin: 0 20rpx;
  font-size: 28rpx;
}

.search-btn {
  padding: 10rpx 30rpx;
  background-color: #3A7BF8;
  color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.search-tips {
  margin-top: 20rpx;
  padding: 0 30rpx;
  font-size: 24rpx;
  color: #999;
}

.history-container {
  width: 100%;
  margin-bottom: 40rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.history-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.clear-history {
  font-size: 28rpx;
  color: #999;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.history-item {
  display: flex;
  align-items: center;
  margin: 10rpx;
  padding: 15rpx 30rpx;
  background-color: #fff;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.history-item icon {
  margin-right: 10rpx;
}

.intro-container {
  width: 100%;
  margin-top: 40rpx;
}

.intro-container .card {
  margin: 0;
}

.intro-container .text view {
  margin: 10rpx 0;
  padding-left: 20rpx;
}