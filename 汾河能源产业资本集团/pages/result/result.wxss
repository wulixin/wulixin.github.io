/**result.wxss**/
.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 加载中样式 */
.loading-container {
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.loading text {
  color: #999;
  font-size: 28rpx;
}

/* 错误提示样式 */
.error-container {
  height: 60vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.error-text {
  margin: 30rpx 0;
  color: #666;
  font-size: 32rpx;
}

.back-btn {
  margin-top: 40rpx;
  padding: 20rpx 60rpx;
  background-color: #3A7BF8;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
}

/* 公司信息样式 */
.company-header {
  margin-bottom: 40rpx;
  text-align: center;
}

.company-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.info-container {
  margin-bottom: 60rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  color: #333;
  font-size: 32rpx;
  font-weight: bold;
}

.card-title icon {
  margin-right: 10rpx;
}

.card-content {
  color: #666;
  font-size: 28rpx;
  line-height: 1.6;
}

.highlight {
  color: #3A7BF8;
  font-weight: bold;
  font-size: 32rpx;
}

/* 底部按钮样式 */
.action-container {
  display: flex;
  justify-content: space-between;
  padding: 30rpx 0;
}

.action-btn {
  flex: 1;
  margin: 0 20rpx;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 32rpx;
}

.action-btn.back {
  background-color: #f5f5f5;
  color: #666;
}

.action-btn.share {
  background-color: #3A7BF8;
  color: #fff;
}